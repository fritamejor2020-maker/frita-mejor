# ============================================================
# FRITA MEJOR — Variables de entorno
# ============================================================
# INSTRUCCIONES para nuevo PC / nuevo colaborador:
#
# 1. Copia este archivo y renómbralo a ".env" (sin el .example)
# 2. Rellena los valores con los del Dashboard de Supabase:
#    Ir a: https://supabase.com/dashboard/project/uevcotmnffftoelscjua/settings/api-keys
#    → Pestaña "Claves API de Legacy anon y service_role"
#    → Copiar "Project URL" y la clave "anon public"
# 3. Ejecuta: npm install && npm run dev
# ============================================================

VITE_SUPABASE_URL=https://uevcotmnffftoelscjua.supabase.co
VITE_SUPABASE_ANON_KEY=pegar_aqui_la_clave_anon_del_dashboard

# ── Push Notifications (Web Push / VAPID) ──────────────────────────────────────
# Genera las claves ejecutando UNA SOLA VEZ en la terminal:
#   npx web-push generate-vapid-keys
#
# Luego:
#  1. Copia la "Public Key" aquí abajo (VITE_VAPID_PUBLIC_KEY)
#  2. En Supabase Dashboard → Edge Functions → notify-dejadors → Secrets:
#     - VAPID_PUBLIC_KEY  = la misma Public Key
#     - VAPID_PRIVATE_KEY = la Private Key (NUNCA la pongas aquí)
#     - VAPID_SUBJECT     = mailto:tu@email.com
VITE_VAPID_PUBLIC_KEY=pegar_aqui_la_vapid_public_key
